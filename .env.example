# HuggingFace token for gated models (optional)
HF_TOKEN=

# Local directory to cache downloaded models
HF_HOME=./models

# Port overrides (defaults shown)
PROXY_PORT=30000
DASHBOARD_PORT=30001
MANAGEMENT_PORT=30099

# Restrict which GPUs are visible (default: all)
# NVIDIA_VISIBLE_DEVICES=0,1

# Override idle timeout for all models (minutes)
# LLM_IDLE_TIMEOUT_MINUTES=5
